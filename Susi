function renderUserList(){
  document.getElementById('admin-user-list').innerHTML=D.users.map(u=>`
    <div class="user-card ${u.id===D.activeUserId?'sel':''}" onclick="selectUser('${u.id}')">
      <div class="user-ava">${u.name?u.name[0].toUpperCase():'?'}</div>
      <div><div class="user-name">${u.name||'Unbenannt'}</div><div class="user-info">${u.location||''}</div></div>
      ${u.id===D.activeUserId?'<div class="u-active">Aktiv</div>':''}
    </div>`).join('');
}

function selectUser(id){
  editUID=id; D.activeUserId=id; save(); renderUserList();
  const u=D.users.find(u=>u.id===id); if(!u)return;
  document.getElementById('ue-name').value=u.name||'';
  document.getElementById('ue-loc').value=u.location||'';
  document.getElementById('ue-wa').value=u.whatsapp||'';
  document.getElementById('ue-ec1n').value=u.ec1name||'';
  document.getElementById('ue-ec1p').value=u.ec1num||'';
  document.getElementById('ue-ec2n').value=u.ec2name||'';
  document.getElementById('ue-ec2p').value=u.ec2num||'';
  document.getElementById('user-edit-sec').style.display='block';
  document.getElementById('termine-for').textContent=u.name||'';
  document.getElementById('modules-for-user').textContent=u.name||'den Nutzer';
  renderAdminTermine();
}

function saveUser(){
  const u=D.users.find(u=>u.id===editUID); if(!u)return;
  u.name=document.getElementById('ue-name').value; u.location=document.getElementById('ue-loc').value;
  u.whatsapp=document.getElementById('ue-wa').value; u.ec1name=document.getElementById('ue-ec1n').value;
  u.ec1num=document.getElementById('ue-ec1p').value; u.ec2name=document.getElementById('ue-ec2n').value;
  u.ec2num=document.getElementById('ue-ec2p').value; save(); renderUserList();
}

function addNewUser(){ const id='u'+Date.now(); D.users.push({id,name:'Neuer Nutzer',location:'',whatsapp:'',ec1name:'',ec1num:'',ec2name:'',ec2num:'',termine:[]}); save(); selectUser(id); }
function deleteUser(){ if(D.users.length<=1){alert('Mindestens ein Nutzer muss vorhanden sein.');return;} if(!confirm('Nutzer wirklich löschen?'))return; D.users=D.users.filter(u=>u.id!==editUID); D.activeUserId=D.users[0].id; editUID=null; save(); document.getElementById('user-edit-sec').style.display='none'; renderUserList(); }

function renderAdminTermine(){
  const u=activeUser(); const cols=['#e85c45','#2b9fd8','#e8a020','#25c260','#8b5cf6','#f0934a'];
  document.getElementById('admin-termine-list').innerHTML=(u?.termine||[]).sort((a,b)=>a.time.localeCompare(b.time)).map((t,i)=>`
    <div class="a-item" style="border-left:3px solid ${cols[i%cols.length]}">
      <div class="a-item-time">${t.time}</div><div style="font-size:20px">${t.emoji||'📌'}</div>
      <div style="flex:1"><div class="a-item-main">${t.text}</div><div class="a-item-sub">${t.sub||''}</div></div>
      <button class="a-del" onclick="adminDelTermin(${i})">✕</button>
    </div>`).join('');
}

function adminAddTermin(){ const u=activeUser(); if(!u)return; const time=document.getElementById('at-time').value.trim(),emoji=document.getElementById('at-emoji').value.trim()||'📌',text=document.getElementById('at-text').value.trim(),sub=document.getElementById('at-sub').value.trim(); if(!time||!text)return; if(!u.termine)u.termine=[]; u.termine.push({time,emoji,text,sub}); save(); renderAdminTermine(); renderTermine(); renderButtons(); ['at-time','at-emoji','at-text','at-sub'].forEach(id=>document.getElementById(id).value=''); }
function adminDelTermin(i){ const u=activeUser(); u.termine.splice(i,1); save(); renderAdminTermine(); renderTermine(); }

function loadAvatarForm(){
  document.getElementById('av-name').value=D.avatarName||'Susi';
  document.getElementById('av-mor').value=D.messages.morning;
  document.getElementById('av-noo').value=D.messages.noon;
  document.getElementById('av-aft').value=D.messages.afternoon;
  document.getElementById('av-eve').value=D.messages.evening;
  document.getElementById('av-key').value=D.apiKey||'';
  document.getElementById('av-owm').value=D.owmKey||'';
  document.getElementById('av-prompt').value=D.systemPrompt||DEF.systemPrompt;
}

function saveAvatar(){
  D.avatarName=document.getElementById('av-name').value; D.messages.morning=document.getElementById('av-mor').value; D.messages.noon=document.getElementById('av-noo').value; D.messages.afternoon=document.getElementById('av-aft').value; D.messages.evening=document.getElementById('av-eve').value; D.apiKey=document.getElementById('av-key').value; D.owmKey=document.getElementById('av-owm').value; D.systemPrompt=document.getElementById('av-prompt').value; save();
  document.getElementById('avatar-display-name').textContent='✨ '+(D.avatarName||'Susi');
}

function renderAdminNews(){ document.getElementById('admin-news-list').innerHTML=(D.customNews||[]).map((n,i)=>`<div class="a-item"><div style="flex:1"><div class="a-item-main">${n.title}</div><div class="a-item-sub">${n.text}</div></div><button class="a-del" onclick="delNews(${i})">✕</button></div>`).join('')||'<div style="color:rgba(255,255,255,.35);font-size:14px;font-weight:600">Noch keine eigenen Nachrichten.</div>'; }
function addNews(){ const t=document.getElementById('nn-title').value.trim(),tx=document.getElementById('nn-text').value.trim(); if(!t)return; if(!D.customNews)D.customNews=[]; D.customNews.unshift({title:t,text:tx}); save(); renderAdminNews(); document.getElementById('nn-title').value=''; document.getElementById('nn-text').value=''; }
function delNews(i){ D.customNews.splice(i,1); save(); renderAdminNews(); }

function renderAdminEvents(){ document.getElementById('admin-events-list').innerHTML=(D.events||[]).map((e,i)=>`<div class="a-item"><div style="flex:1"><div class="a-item-main">${e.title}</div><div class="a-item-sub">${e.day}. ${e.month} · ${e.time} · ${e.place}</div></div><button class="a-del" onclick="delEvent(${i})">✕</button></div>`).join(''); }
function addEvent(){ const day=document.getElementById('ne-day').value.trim(),month=document.getElementById('ne-month').value.trim(),time=document.getElementById('ne-time').value.trim(),title=document.getElementById('ne-title').value.trim(),place=document.getElementById('ne-place').value.trim(); if(!title||!day)return; D.events.unshift({day,month,time,title,place}); save(); renderAdminEvents(); renderEvents(); ['ne-day','ne-month','ne-time','ne-title','ne-place'].forEach(id=>document.getElementById(id).value=''); }
function delEvent(i){ D.events.splice(i,1); save(); renderAdminEvents(); renderEvents(); }

function changeDocPin(){ const p=document.getElementById('new-doc-pin').value.trim(); if(p.length<4||!/^\d+$/.test(p)){alert('Bitte einen 4-stelligen numerischen PIN eingeben.');return;} D.docPin=p; save(); document.getElementById('new-doc-pin').value=''; alert('✅ Arzt-PIN geändert!'); }
function changePw(){ const p=document.getElementById('new-pw').value; if(!p||p.length<4){alert('Mindestens 4 Zeichen!');return;} D.adminPw=p; save(); document.getElementById('new-pw').value=''; alert('✅ Passwort geändert!'); }
function exportData(){ const b=new Blob([JSON.stringify(D,null,2)],{type:'application/json'}); const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download='susi-daten-v4.json'; a.click(); }
function importData(e){ const f=e.target.files[0]; if(!f)return; const r=new FileReader(); r.onload=ev=>{ try{D=JSON.parse(ev.target.result);save();loadAdminForms();alert('✅ Importiert!');} catch{alert('❌ Ungültige Datei');} }; r.readAsText(f); }

</script>
</body>
</html>
