<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Susi – Deine persönliche Begleiterin</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f7f2eb; --card:#fff; --text:#1a1a1a; --muted:#777;
  --red:#e85c45; --blue:#2b9fd8; --yellow:#e8a020; --green:#25c260;
  --purple:#8b5cf6; --darkred:#dc2626; --teal:#0891b2;
  --shadow:0 6px 28px rgba(0,0,0,0.12); --shadow-lg:0 14px 50px rgba(0,0,0,0.18);
  --r:24px; --r-sm:16px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* SCREENS */
.screen{display:none;flex-direction:column;min-height:100vh}
.screen.active{display:flex}

/* ── AVATAR SECTION ── */
.avatar-section{
  background:linear-gradient(160deg,#fce8e4 0%,#e8effe 100%);
  padding:14px 16px 0;display:flex;flex-direction:column;align-items:center;
  border-bottom:3px solid rgba(0,0,0,0.06);
}
.top-bar{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;gap:8px}
.clock-pill{background:white;border-radius:50px;padding:8px 18px;font-size:20px;font-weight:900;color:var(--red);box-shadow:0 2px 12px rgba(0,0,0,0.1)}
.date-pill{background:white;border-radius:50px;padding:8px 14px;font-size:14px;font-weight:700;color:#555;box-shadow:0 2px 12px rgba(0,0,0,0.1);flex:1;text-align:center}
.gps-pill{background:white;border-radius:50px;padding:8px 12px;font-size:13px;font-weight:800;color:var(--blue);box-shadow:0 2px 12px rgba(0,0,0,0.1);cursor:pointer;white-space:nowrap;display:block !important}
.gps-pill.on{background:var(--blue);color:white}

.avatar-wrap{position:relative;width:148px;height:148px}
.avatar-glow{position:absolute;inset:-10px;border-radius:50%;background:radial-gradient(circle,rgba(232,92,69,.22) 0%,transparent 70%);animation:gpulse 3s ease-in-out infinite}
@keyframes gpulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.1);opacity:.4}}
.avatar-svg{width:148px;height:148px;filter:drop-shadow(0 8px 20px rgba(200,80,70,.22))}
.sdw{position:absolute;bottom:6px;right:6px;width:26px;height:26px;background:var(--green);border-radius:50%;border:3px solid white;display:none;align-items:center;justify-content:center}
.sdw.on{display:flex}
.sdot{width:9px;height:9px;background:white;border-radius:50%;animation:sd .5s infinite alternate}
@keyframes sd{from{opacity:1;transform:scale(1)}to{opacity:.3;transform:scale(.6)}}

.avatar-name-row{display:flex;align-items:center;gap:8px;margin-top:6px}
.avatar-name{font-size:24px;font-weight:900;color:var(--red)}
.online-dot{width:12px;height:12px;background:var(--green);border-radius:50%;border:2px solid white;animation:gpulse 2s infinite}

.speech-bubble{
  background:white;border-radius:var(--r);border-bottom-left-radius:4px;
  padding:14px 20px;margin:10px 8px 16px;font-size:18px;font-weight:700;
  color:var(--text);box-shadow:var(--shadow);width:100%;max-width:420px;
  text-align:center;min-height:58px;display:flex;align-items:center;justify-content:center;
  line-height:1.4;position:relative;
}
.speech-bubble::after{content:'';position:absolute;bottom:-13px;left:32px;border-left:14px solid transparent;border-top:13px solid white}
.tdots{display:none;gap:5px}.tdots.on{display:flex}
.tdots span{width:9px;height:9px;background:#ccc;border-radius:50%;animation:td 1s infinite}
.tdots span:nth-child(2){animation-delay:.2s}.tdots span:nth-child(3){animation-delay:.4s}
@keyframes td{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

/* ── BUTTONS ── */
.buttons-section{padding:16px 14px 90px}
.section-label{font-size:13px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:2px;margin-bottom:12px}
.buttons-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.main-btn{border:none;border-radius:var(--r);padding:20px 12px 16px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:9px;position:relative;overflow:hidden;text-align:center;min-height:126px;transition:transform .15s,box-shadow .15s;box-shadow:var(--shadow)}
.main-btn:active{transform:scale(.95);box-shadow:0 4px 12px rgba(0,0,0,.15)}
.btn-termine {background:linear-gradient(145deg,#ff7a65,var(--red))}
.btn-wetter  {background:linear-gradient(145deg,#5bc8f5,var(--blue))}
.btn-news    {background:linear-gradient(145deg,#f8c84a,var(--yellow))}
.btn-wa      {background:linear-gradient(145deg,#4de07a,var(--green))}
.btn-events  {background:linear-gradient(145deg,#b47bff,var(--purple))}
.btn-notfall {background:linear-gradient(145deg,#ff6060,var(--darkred))}
.btn-icon{font-size:44px;line-height:1;filter:drop-shadow(0 2px 4px rgba(0,0,0,.2))}
.btn-label{font-size:18px;font-weight:900;color:white;line-height:1.2;text-shadow:0 1px 3px rgba(0,0,0,.2)}
.btn-sub{font-size:13px;font-weight:700;color:rgba(255,255,255,.85);margin-top:-6px}
.btn-badge{position:absolute;top:10px;right:10px;background:white;font-size:12px;font-weight:900;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.btn-termine .btn-badge{color:var(--red)}.btn-news .btn-badge{color:var(--yellow)}
.btn-wa .btn-badge{color:var(--green)}

/* ── FAB ── */
.fab{position:fixed;bottom:20px;right:18px;border:none;border-radius:50%;width:68px;height:68px;font-size:28px;cursor:pointer;box-shadow:0 8px 28px rgba(232,92,69,.5);z-index:100;transition:transform .2s;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#ff7a65,var(--red))}
.fab:active{transform:scale(.9)}
/* Doctor FAB */
.fab-doc{position:fixed;bottom:20px;left:18px;border:none;border-radius:50%;width:60px;height:60px;font-size:24px;cursor:pointer;box-shadow:0 8px 28px rgba(0,145,210,.45);z-index:100;background:linear-gradient(135deg,#5bc8f5,var(--blue));display:flex;align-items:center;justify-content:center}

/* ── REMINDER TOAST ── */
.toast{position:fixed;top:20px;left:50%;transform:translateX(-50%) translateY(-130px);background:white;border-radius:var(--r);padding:16px 22px;box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:14px;z-index:600;transition:transform .4s cubic-bezier(.34,1.56,.64,1);max-width:92vw;border-left:5px solid var(--red)}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast-ico{font-size:34px}.toast-ttl{font-size:19px;font-weight:900}.toast-sub{font-size:14px;color:var(--muted);font-weight:600}
.toast-x{margin-left:auto;background:#f5f5f5;border:none;border-radius:50%;width:32px;height:32px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center}

/* ── OVERLAY / MODAL ── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.52);z-index:300;align-items:flex-end;justify-content:center}
.overlay.on{display:flex}
.modal{background:white;border-radius:var(--r) var(--r) 0 0;width:100%;max-width:620px;max-height:90vh;overflow-y:auto;animation:sup .3s cubic-bezier(.34,1.4,.64,1)}
@keyframes sup{from{transform:translateY(100%)}to{transform:translateY(0)}}
.mhdr{display:flex;align-items:center;justify-content:space-between;padding:20px 20px 14px;position:sticky;top:0;background:white;z-index:1;border-bottom:2px solid #f0f0f0}
.mhdr-title{font-size:22px;font-weight:900}
.mx{background:#f5f5f5;border:none;border-radius:50%;width:42px;height:42px;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.mbody{padding:18px 20px 32px}

/* ── TERMINE ── */
.termin-card{display:flex;align-items:center;gap:14px;background:#fafafa;border-radius:var(--r-sm);padding:16px 18px;margin-bottom:12px;border-left:5px solid #ddd}
.termin-card.now{border-left-color:var(--green);background:#f0fdf4}
.termin-card.past{opacity:.45}
.tc-time{font-size:22px;font-weight:900;color:var(--red);min-width:64px}
.tc-ico{font-size:28px}
.tc-text{font-size:18px;font-weight:800}
.tc-sub{font-size:14px;color:var(--muted);font-weight:600;margin-top:2px}
.tc-status{margin-left:auto;font-size:13px;font-weight:800;color:var(--green)}

/* ── WETTER ── */
.wt-main{text-align:center;padding:20px 0 12px}
.wt-ico{font-size:88px}.wt-temp{font-size:62px;font-weight:900;color:var(--blue);line-height:1}
.wt-desc{font-size:22px;font-weight:700;color:#555;margin-top:4px}
.wt-loc{font-size:15px;color:var(--muted);margin-top:4px;font-weight:600}
.wt-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:18px}
.wt-cell{background:#f4f8ff;border-radius:var(--r-sm);padding:14px 8px;text-align:center}
.wt-val{font-size:18px;font-weight:800;color:var(--blue)}
.wt-lbl{font-size:13px;color:var(--muted);font-weight:700;margin-top:2px}
.wt-tip{background:#fff8e8;border-radius:var(--r-sm);padding:14px;margin-top:12px;font-size:16px;font-weight:700;color:#7a5500;text-align:center}

/* ── NEWS ── */
.news-item{padding:16px 0;border-bottom:2px solid #f5f5f5}
.news-cat{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--yellow);margin-bottom:4px}
.news-ttl{font-size:19px;font-weight:900;line-height:1.3}
.news-sum{font-size:16px;color:#555;margin-top:4px;font-weight:600;line-height:1.4}
.news-time{font-size:13px;color:#aaa;margin-top:6px;font-weight:600}
.news-src{font-size:12px;color:var(--blue);font-weight:700;margin-top:2px;cursor:pointer;text-decoration:underline}
.gps-status-bar{background:#e8f4fd;border-radius:var(--r-sm);padding:12px 16px;margin-bottom:14px;display:flex;align-items:center;gap:10px;font-size:15px;font-weight:700;color:var(--blue)}

/* ── WHATSAPP ── */
.wa-grp{background:#f9fef9;border-radius:var(--r-sm);padding:16px;display:flex;align-items:center;gap:14px;margin-bottom:12px;cursor:pointer;border:2px solid #e0f5e0}
.wa-ava{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0}
.wa-name{font-size:19px;font-weight:900}.wa-prev{font-size:15px;color:#555;font-weight:600}.wa-time{font-size:13px;color:#aaa}
.wa-unread{background:var(--green);color:white;font-size:13px;font-weight:900;min-width:26px;height:26px;border-radius:13px;display:flex;align-items:center;justify-content:center;padding:0 7px}
.wa-open{width:100%;border:none;border-radius:var(--r-sm);background:linear-gradient(135deg,#25D366,#128C7E);color:white;padding:20px;font-size:20px;font-weight:900;font-family:'Nunito',sans-serif;cursor:pointer;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:10px}

/* ── EVENTS ── */
.ev-card{background:#fafafa;border-radius:var(--r-sm);padding:16px;margin-bottom:12px;display:flex;gap:14px}
.ev-date{border-radius:14px;padding:10px 12px;text-align:center;flex-shrink:0;min-width:60px;color:white}
.ev-d{font-size:26px;font-weight:900;line-height:1}.ev-m{font-size:11px;font-weight:700;text-transform:uppercase}
.ev-ttl{font-size:18px;font-weight:900;margin-bottom:2px}.ev-place{font-size:15px;color:#555;font-weight:600}.ev-t{font-size:14px;font-weight:700;margin-top:4px}

/* ── NOTFALL ── */
.nf-btn{width:100%;border:none;border-radius:var(--r);background:linear-gradient(135deg,#ff6060,var(--darkred));color:white;padding:28px;font-size:26px;font-weight:900;font-family:'Nunito',sans-serif;cursor:pointer;margin-bottom:14px;box-shadow:0 8px 28px rgba(220,38,38,.4);display:flex;align-items:center;justify-content:center;gap:12px}
.nf-contact{background:#fafafa;border-radius:var(--r-sm);padding:16px;display:flex;align-items:center;gap:14px;margin-bottom:10px;cursor:pointer;border:2px solid #eee}
.nf-ico{font-size:30px}.nf-name{font-size:18px;font-weight:900}.nf-num{font-size:15px;color:#555;font-weight:600}

/* ── CHAT ── */
.chat-box{background:#f9f9f9;border-radius:var(--r-sm);padding:14px;margin-bottom:14px;max-height:260px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;min-height:80px}
.cmsg{max-width:85%;padding:12px 16px;border-radius:18px;font-size:16px;font-weight:600;line-height:1.4}
.cmsg.user{align-self:flex-end;background:var(--red);color:white;border-bottom-right-radius:4px}
.cmsg.susi{align-self:flex-start;background:white;box-shadow:0 2px 8px rgba(0,0,0,.08);border-bottom-left-radius:4px}
.chat-row{display:flex;gap:10px;margin-bottom:10px}
.chat-in{flex:1;border:2px solid #e0e0e0;border-radius:var(--r-sm);padding:14px 16px;font-size:17px;font-family:'Nunito',sans-serif;outline:none;background:white}
.chat-in:focus{border-color:var(--red)}
.chat-send{background:var(--red);color:white;border:none;border-radius:var(--r-sm);padding:14px 18px;font-size:20px;cursor:pointer}
.chat-mic{background:var(--blue);color:white;border:none;border-radius:var(--r-sm);padding:14px 16px;font-size:20px;cursor:pointer}
.chat-mic.active{background:var(--darkred);animation:lpulse 1s infinite}
@keyframes lpulse{0%,100%{box-shadow:0 8px 28px rgba(220,38,38,.6)}50%{box-shadow:0 8px 48px rgba(220,38,38,.9),0 0 0 12px rgba(220,38,38,.12)}}

/* ── ARZT PANEL ── */
.doc-panel{background:linear-gradient(160deg,#e8f4fd,#f0e8ff);border-radius:var(--r);padding:20px;margin-bottom:14px}
.doc-panel-title{font-size:20px;font-weight:900;color:var(--blue);margin-bottom:4px;display:flex;align-items:center;gap:8px}
.doc-panel-sub{font-size:14px;color:var(--muted);font-weight:600;margin-bottom:16px}
.doc-in{width:100%;border:2px solid rgba(43,159,216,.3);border-radius:var(--r-sm);padding:14px 16px;font-size:17px;font-family:'Nunito',sans-serif;outline:none;background:white;margin-bottom:10px}
.doc-in:focus{border-color:var(--blue)}
.doc-row{display:flex;gap:10px;margin-bottom:10px}
.doc-row .doc-in{margin-bottom:0}
.doc-btn{background:var(--blue);color:white;border:none;border-radius:var(--r-sm);padding:14px 20px;font-size:16px;font-weight:800;font-family:'Nunito',sans-serif;cursor:pointer;display:flex;align-items:center;gap:8px}
.doc-btn.green{background:var(--green)}
.doc-btn.red{background:var(--darkred)}
.doc-mic-btn{background:linear-gradient(135deg,var(--purple),#6d28d9);color:white;border:none;border-radius:var(--r-sm);padding:14px 20px;font-size:16px;font-weight:800;font-family:'Nunito',sans-serif;cursor:pointer;display:flex;align-items:center;gap:8px;width:100%;justify-content:center;margin-bottom:12px}
.doc-mic-btn.listening{background:linear-gradient(135deg,var(--darkred),#991b1b);animation:lpulse 1s infinite}
.voice-status{background:rgba(139,92,246,.1);border:2px solid rgba(139,92,246,.3);border-radius:var(--r-sm);padding:14px;margin-bottom:12px;font-size:15px;font-weight:700;color:var(--purple);text-align:center;display:none}
.voice-status.on{display:block}
.parsed-preview{background:#f0fdf4;border:2px solid rgba(37,194,96,.3);border-radius:var(--r-sm);padding:14px;margin-bottom:12px;display:none}
.parsed-preview.on{display:block}
.pp-title{font-size:14px;font-weight:800;color:var(--green);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.pp-item{font-size:16px;font-weight:700;margin-bottom:4px}
.pp-sub{font-size:14px;color:var(--muted)}

/* ── PIN OVERLAY ── */
.pin-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:400;align-items:center;justify-content:center;padding:20px}
.pin-overlay.on{display:flex}
.pin-card{background:white;border-radius:var(--r);padding:32px 28px;width:100%;max-width:340px;text-align:center;animation:sup .3s cubic-bezier(.34,1.4,.64,1)}
.pin-logo{font-size:56px;margin-bottom:12px}
.pin-title{font-size:24px;font-weight:900;margin-bottom:4px}
.pin-sub{font-size:15px;color:var(--muted);font-weight:600;margin-bottom:24px}
.pin-display{font-size:40px;font-weight:900;letter-spacing:12px;color:var(--blue);margin-bottom:20px;min-height:52px;font-family:monospace}
.pin-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px}
.pin-key{background:#f5f5f5;border:none;border-radius:16px;padding:18px;font-size:24px;font-weight:900;font-family:'Nunito',sans-serif;cursor:pointer;transition:background .15s;color:var(--text)}
.pin-key:active{background:#e0e0e0}
.pin-key.zero{grid-column:2}
.pin-key.del{background:#fee2e2;color:var(--darkred)}
.pin-err{color:var(--darkred);font-size:15px;font-weight:700;min-height:22px}
.pin-back{margin-top:10px;background:none;border:none;color:var(--muted);font-size:15px;font-weight:700;cursor:pointer;font-family:'Nunito',sans-serif}

/* ── ADMIN LOGIN ── */
#login-screen{background:linear-gradient(160deg,#1a1a2e,#16213e,#0f3460);align-items:center;justify-content:center;padding:32px 20px}
.login-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);border-radius:var(--r);padding:36px 28px;width:100%;max-width:360px;backdrop-filter:blur(20px)}
.login-logo{width:80px;height:80px;background:linear-gradient(135deg,var(--red),#c060a0);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:40px;margin:0 auto 20px;box-shadow:0 12px 40px rgba(232,92,69,.4)}
.login-title{text-align:center;font-size:26px;font-weight:900;color:white;margin-bottom:4px}
.login-sub{text-align:center;font-size:14px;color:rgba(255,255,255,.5);margin-bottom:28px}
.l-in{width:100%;background:rgba(255,255,255,.1);border:2px solid rgba(255,255,255,.2);border-radius:14px;padding:15px 16px;font-size:17px;font-family:'Nunito',sans-serif;color:white;margin-bottom:14px;outline:none;transition:border-color .2s}
.l-in:focus{border-color:var(--red)}.l-in::placeholder{color:rgba(255,255,255,.4)}
.l-go{width:100%;background:linear-gradient(135deg,var(--red),#c04030);color:white;border:none;border-radius:14px;padding:17px;font-size:19px;font-weight:900;font-family:'Nunito',sans-serif;cursor:pointer;box-shadow:0 8px 24px rgba(232,92,69,.4)}
.l-err{color:#ff8080;font-size:15px;font-weight:700;text-align:center;margin-top:12px;display:none}

/* ── ADMIN SCREEN ── */
#admin-screen{background:#1a1a2e;color:white}
.a-hdr{background:linear-gradient(135deg,#16213e,#0f3460);padding:20px 18px;display:flex;align-items:center;gap:14px;border-bottom:1px solid rgba(255,255,255,.1);position:sticky;top:0;z-index:10}
.a-logo{width:46px;height:46px;background:var(--red);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px}
.a-ttl{font-size:20px;font-weight:900}.a-sub{font-size:13px;color:rgba(255,255,255,.5)}
.a-back{margin-left:auto;background:rgba(255,255,255,.12);border:none;color:white;border-radius:10px;padding:9px 18px;font-size:15px;font-weight:700;font-family:'Nunito',sans-serif;cursor:pointer}
.a-tabs{display:flex;background:rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.1);overflow-x:auto}
.a-tab{padding:13px 16px;font-size:14px;font-weight:800;color:rgba(255,255,255,.5);cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;font-family:'Nunito',sans-serif;background:none;border-left:none;border-right:none;border-top:none}
.a-tab.active{color:white;border-bottom-color:var(--red)}
.a-body{padding:18px 16px;flex:1;overflow-y:auto}
.tpane{display:none}.tpane.active{display:block}
.a-sec{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--r);padding:20px;margin-bottom:16px}
.a-sec-ttl{font-size:17px;font-weight:900;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.a-lbl{font-size:13px;font-weight:700;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.a-in{width:100%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:12px;padding:13px 14px;font-size:16px;font-family:'Nunito',sans-serif;color:white;margin-bottom:12px;outline:none;transition:border-color .2s}
.a-in:focus{border-color:var(--red)}.a-in::placeholder{color:rgba(255,255,255,.35)}
.a-row{display:flex;gap:10px;margin-bottom:12px}.a-row .a-in{margin-bottom:0}
.a-btn{background:var(--red);color:white;border:none;border-radius:12px;padding:13px 20px;font-size:15px;font-weight:800;font-family:'Nunito',sans-serif;cursor:pointer;display:inline-flex;align-items:center;gap:6px}
.a-btn.sec{background:rgba(255,255,255,.15)}.a-btn.danger{background:rgba(220,38,38,.5)}
.a-item{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.08);border-radius:12px;padding:12px 14px;margin-bottom:8px}
.a-item-main{flex:1;font-size:15px;font-weight:700}.a-item-sub{font-size:13px;opacity:.55;font-weight:600}
.a-item-time{font-size:15px;font-weight:900;color:var(--red);min-width:54px}
.a-del{background:rgba(220,38,38,.3);border:none;color:#ff8080;border-radius:8px;width:32px;height:32px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.user-card{background:rgba(255,255,255,.08);border-radius:var(--r-sm);padding:16px;margin-bottom:10px;display:flex;align-items:center;gap:14px;cursor:pointer;border:2px solid transparent;transition:border-color .2s}
.user-card.sel{border-color:var(--red)}
.user-ava{width:50px;height:50px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
.user-name{font-size:17px;font-weight:900}.user-info{font-size:13px;opacity:.55;font-weight:600}
.u-active{margin-left:auto;background:rgba(37,194,96,.2);border:1px solid rgba(37,194,96,.4);color:var(--green);border-radius:8px;padding:5px 12px;font-size:12px;font-weight:800}
.pin-setting-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.admin-trigger{position:fixed;bottom:0;left:0;width:60px;height:60px;opacity:0;z-index:50;cursor:default}

::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:rgba(0,0,0,.18);border-radius:4px}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════
     HOME SCREEN
═══════════════════════════════════════ -->
<div id="home-screen" class="screen active">
  <div class="avatar-section">
    <div class="top-bar">
      <div class="clock-pill" id="clock">--:--</div>
      <div class="date-pill" id="datepill">Heute</div>
      <div class="gps-pill" id="gps-pill" onclick="toggleGPS()">📍 GPS</div>
    </div>

    <div class="avatar-wrap">
      <div class="avatar-glow"></div>
      <svg class="avatar-svg" viewBox="0 0 160 160" xmlns="http://www.w3.org/2000/svg">
        <circle cx="80" cy="80" r="78" fill="#fde8e0" stroke="#e8857a" stroke-width="2.5"/>
        <ellipse cx="80" cy="54" rx="44" ry="46" fill="#7a3a10"/>
        <rect x="67" y="110" width="26" height="22" rx="10" fill="#f5c5a0"/>
        <ellipse cx="80" cy="150" rx="52" ry="26" fill="#e8857a"/>
        <ellipse cx="80" cy="154" rx="42" ry="20" fill="#c96b60"/>
        <ellipse cx="80" cy="80" rx="35" ry="40" fill="#f5c5a0"/>
        <ellipse cx="80" cy="50" rx="38" ry="22" fill="#7a3a10"/>
        <ellipse cx="44" cy="72" rx="14" ry="24" fill="#7a3a10"/>
        <ellipse cx="116" cy="72" rx="14" ry="24" fill="#7a3a10"/>
        <ellipse cx="66" cy="45" rx="12" ry="7" fill="#9a5020" opacity="0.5"/>
        <ellipse cx="44" cy="80" rx="7" ry="10" fill="#f5c5a0"/><ellipse cx="116" cy="80" rx="7" ry="10" fill="#f5c5a0"/>
        <ellipse cx="44" cy="80" rx="4" ry="6" fill="#e8b090"/><ellipse cx="116" cy="80" rx="4" ry="6" fill="#e8b090"/>
        <circle cx="44" cy="90" r="4" fill="#f5c842"/><circle cx="116" cy="90" r="4" fill="#f5c842"/>
        <path d="M58 66 Q67 62 74 65" stroke="#6b3a10" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M86 65 Q93 62 102 66" stroke="#6b3a10" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <ellipse cx="66" cy="74" rx="8.5" ry="8.5" fill="white"/><ellipse cx="94" cy="74" rx="8.5" ry="8.5" fill="white"/>
        <circle cx="67" cy="74" r="5.5" fill="#4a2808"/><circle cx="95" cy="74" r="5.5" fill="#4a2808"/>
        <circle cx="67" cy="74" r="2.8" fill="black"/><circle cx="95" cy="74" r="2.8" fill="black"/>
        <circle cx="69" cy="72" r="1.6" fill="white"/><circle cx="97" cy="72" r="1.6" fill="white"/>
        <ellipse cx="55" cy="85" rx="11" ry="7" fill="#f5a0a0" opacity="0.38"/>
        <ellipse cx="105" cy="85" rx="11" ry="7" fill="#f5a0a0" opacity="0.38"/>
        <ellipse cx="80" cy="88" rx="4" ry="3" fill="#e8a880" opacity="0.5"/>
        <circle cx="77" cy="89" r="2" fill="#d0906a" opacity="0.5"/><circle cx="83" cy="89" r="2" fill="#d0906a" opacity="0.5"/>
        <g id="mouth-grp">
          <path id="m-smile" d="M68 99 Q80 108 92 99" stroke="#d4607a" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path id="m-lower" d="M71 101 Q80 107 89 101" stroke="#d4607a" stroke-width="1.5" fill="#f08090" opacity="0.5" stroke-linecap="round"/>
          <ellipse id="m-open" cx="80" cy="102" rx="7" ry="4" fill="#c03050" opacity="0"/>
          <ellipse id="m-teeth" cx="80" cy="100" rx="5.5" ry="2" fill="white" opacity="0"/>
        </g>
        <rect x="53" y="68" width="23" height="16" rx="8" fill="none" stroke="#7a3a10" stroke-width="2" opacity="0.55"/>
        <rect x="84" y="68" width="23" height="16" rx="8" fill="none" stroke="#7a3a10" stroke-width="2" opacity="0.55"/>
        <line x1="76" y1="76" x2="84" y2="76" stroke="#7a3a10" stroke-width="2" opacity="0.55"/>
        <line x1="40" y1="74" x2="53" y2="74" stroke="#7a3a10" stroke-width="1.5" opacity="0.55"/>
        <line x1="107" y1="74" x2="120" y2="74" stroke="#7a3a10" stroke-width="1.5" opacity="0.55"/>
        <path d="M64 130 Q80 122 96 130" fill="white" opacity="0.55"/>
      </svg>
      <div class="sdw" id="sdw"><div class="sdot"></div></div>
    </div>

    <div class="avatar-name-row">
      <div class="avatar-name" id="avatar-display-name">✨ Susi</div>
      <div class="online-dot"></div>
    </div>
    <div class="speech-bubble" id="speech-bubble">
      <div class="tdots on" id="tdots"><span></span><span></span><span></span></div>
      <span id="bubble-text" style="display:none">Hallo!</span>
    </div>
  </div>

  <div class="buttons-section">
    <div class="section-label">Was möchtest du tun?</div>
    <div class="buttons-grid" id="buttons-grid">
      <!-- dynamisch befüllt durch renderButtons() -->
    </div>
  </div>

  <button class="fab" id="fab-chat" onclick="openOv('ov-chat')" title="Mit Susi sprechen">🎙️</button>
  <button class="fab-doc" id="fab-doc" onclick="openDocPin()" title="Arzt-Zugang">👨‍⚕️</button>
  <div class="admin-trigger" id="admin-trigger"></div>
</div>

<!-- REMINDER TOAST -->
<div class="toast" id="toast">
  <div class="toast-ico" id="t-ico">💊</div>
  <div><div class="toast-ttl" id="t-ttl">Erinnerung</div><div class="toast-sub" id="t-sub"></div></div>
  <button class="toast-x" onclick="closeToast()">✕</button>
</div>

<!-- ═══════ OVERLAYS ═══════ -->

<!-- TERMINE -->
<div class="overlay" id="ov-termine">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">📅 Meine Termine</div><button class="mx" onclick="closeOv('ov-termine')">✕</button></div>
    <div class="mbody" id="mb-termine"></div>
  </div>
</div>

<!-- WETTER -->
<div class="overlay" id="ov-wetter">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">🌤️ Wetter heute</div><button class="mx" onclick="closeOv('ov-wetter')">✕</button></div>
    <div class="mbody" id="mb-wetter">
      <div class="wt-main">
        <div class="wt-ico" id="wt-ico">⏳</div>
        <div class="wt-temp" id="wt-temp">--°</div>
        <div class="wt-desc" id="wt-desc">Wird geladen...</div>
        <div class="wt-loc" id="wt-loc">📍 Standort wird ermittelt</div>
      </div>
      <div class="wt-grid">
        <div class="wt-cell"><div class="wt-val" id="wt-hum">--%</div><div class="wt-lbl">💧 Feuchte</div></div>
        <div class="wt-cell"><div class="wt-val" id="wt-wind">-- km/h</div><div class="wt-lbl">💨 Wind</div></div>
        <div class="wt-cell"><div class="wt-val" id="wt-rain">--%</div><div class="wt-lbl">☔ Regen</div></div>
      </div>
      <div class="wt-tip" id="wt-tip">Wetterdaten werden geladen...</div>
    </div>
  </div>
</div>

<!-- NACHRICHTEN -->
<div class="overlay" id="ov-news">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">📰 Nachrichten</div><button class="mx" onclick="closeOv('ov-news')">✕</button></div>
    <div class="mbody" id="mb-news"><div style="text-align:center;padding:30px;color:#aaa;font-weight:700">Nachrichten werden geladen...</div></div>
  </div>
</div>

<!-- WHATSAPP -->
<div class="overlay" id="ov-wa">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">💬 WhatsApp</div><button class="mx" onclick="closeOv('ov-wa')">✕</button></div>
    <div class="mbody" id="mb-wa"></div>
  </div>
</div>

<!-- EVENTS -->
<div class="overlay" id="ov-events">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">🎭 Veranstaltungen</div><button class="mx" onclick="closeOv('ov-events')">✕</button></div>
    <div class="mbody" id="mb-events"></div>
  </div>
</div>

<!-- NOTFALL -->
<div class="overlay" id="ov-notfall">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">🆘 Hilfe &amp; Notfall</div><button class="mx" onclick="closeOv('ov-notfall')">✕</button></div>
    <div class="mbody">
      <button class="nf-btn" onclick="callNum('112')">📞 Notruf 112</button>
      <div id="mb-notfall"></div>
    </div>
  </div>
</div>

<!-- SUSI CHAT -->
<div class="overlay" id="ov-chat">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-title">🤖 Mit Susi sprechen</div><button class="mx" onclick="closeOv('ov-chat')">✕</button></div>
    <div class="mbody">
      <div class="chat-box" id="chat-box">
        <div class="cmsg susi">Hallo! Ich bin Susi. Du kannst mich alles fragen – ich bin für dich da! 😊</div>
      </div>
      <div class="chat-row">
        <input class="chat-in" id="chat-in" placeholder="Schreib Susi etwas..." onkeydown="if(event.key==='Enter')sendChat()"/>
        <button class="chat-mic" id="chat-mic" onclick="toggleMic()">🎤</button>
        <button class="chat-send" onclick="sendChat()">➤</button>
      </div>
      <div style="font-size:13px;color:#aaa;text-align:center;font-weight:600">Powered by Claude AI · Susi antwortet auf Deutsch</div>
    </div>
  </div>
</div>

<!-- ARZT PANEL -->
<div class="overlay" id="ov-doc">
  <div class="modal">
    <div class="mhdr">
      <div class="mhdr-title">👨‍⚕️ Arzt-Zugang</div>
      <button class="mx" onclick="closeOv('ov-doc')">✕</button>
    </div>
    <div class="mbody">
      <div class="doc-panel">
        <div class="doc-panel-title">🎤 Termin per Sprache eingeben</div>
        <div class="doc-panel-sub">Sprechen Sie einfach – Susi versteht und trägt ein</div>
        <button class="doc-mic-btn" id="doc-mic-btn" onclick="toggleDocMic()">🎤 Termin per Sprache eingeben</button>
        <div class="voice-status" id="voice-status">🎤 Bitte sprechen... z.B.: "Morgen um 10 Uhr Blutdruck-Kontrolle" oder "Jeden Tag 8 Uhr Aspirin 100mg"</div>
        <div class="parsed-preview" id="parsed-preview">
          <div class="pp-title">✅ Erkannt – bitte bestätigen</div>
          <div id="pp-content"></div>
          <div style="display:flex;gap:10px;margin-top:12px">
            <button class="doc-btn green" onclick="confirmParsed()">✓ Speichern</button>
            <button class="doc-btn red" onclick="cancelParsed()">✕ Abbrechen</button>
          </div>
        </div>
      </div>

      <div style="border-top:2px solid #f0f0f0;padding-top:16px;margin-top:4px">
        <div style="font-size:16px;font-weight:900;margin-bottom:14px;color:#555">✏️ Oder manuell eingeben</div>
        <div class="doc-row">
          <input class="doc-in" id="doc-time" placeholder="Zeit z.B. 08:00" style="max-width:100px"/>
          <input class="doc-in" id="doc-emoji" placeholder="💊" style="max-width:62px"/>
          <input class="doc-in" id="doc-text" placeholder="Termin / Medikament"/>
        </div>
        <input class="doc-in" id="doc-sub" placeholder="Details z.B. 1 Tablette Blutdruck, nüchtern nehmen"/>
        <div class="doc-row">
          <input class="doc-in" id="doc-repeat" placeholder="Wiederholung z.B. täglich, Mo/Mi/Fr"/>
        </div>
        <button class="doc-btn" onclick="addDocTermin()">+ Termin speichern</button>
      </div>

      <div style="margin-top:20px;border-top:2px solid #f0f0f0;padding-top:16px">
        <div style="font-size:16px;font-weight:900;margin-bottom:12px;color:#555">📋 Aktuelle Termine</div>
        <div id="doc-termin-list"></div>
      </div>
    </div>
  </div>
</div>

<!-- PIN OVERLAY -->
<div class="pin-overlay" id="pin-overlay">
  <div class="pin-card">
    <div class="pin-logo">👨‍⚕️</div>
    <div class="pin-title">Arzt-Zugang</div>
    <div class="pin-sub">Bitte PIN eingeben</div>
    <div class="pin-display" id="pin-display">----</div>
    <div class="pin-grid">
      <button class="pin-key" onclick="pinKey('1')">1</button>
      <button class="pin-key" onclick="pinKey('2')">2</button>
      <button class="pin-key" onclick="pinKey('3')">3</button>
      <button class="pin-key" onclick="pinKey('4')">4</button>
      <button class="pin-key" onclick="pinKey('5')">5</button>
      <button class="pin-key" onclick="pinKey('6')">6</button>
      <button class="pin-key" onclick="pinKey('7')">7</button>
      <button class="pin-key" onclick="pinKey('8')">8</button>
      <button class="pin-key" onclick="pinKey('9')">9</button>
      <button class="pin-key zero" onclick="pinKey('0')">0</button>
      <button class="pin-key del" onclick="pinDel()">⌫</button>
    </div>
    <div class="pin-err" id="pin-err"></div>
    <button class="pin-back" onclick="closePinOverlay()">Abbrechen</button>
  </div>
</div>

<!-- ═══════ LOGIN ═══════ -->
<div id="login-screen" class="screen">
  <div class="login-card">
    <div class="login-logo">🔐</div>
    <div class="login-title">Admin-Bereich</div>
    <div class="login-sub">Susi Companion – Verwaltung</div>
    <input type="text" class="l-in" id="l-user" placeholder="Benutzername" autocomplete="off"/>
    <input type="password" class="l-in" id="l-pass" placeholder="Passwort" onkeydown="if(event.key==='Enter')doLogin()"/>
    <button class="l-go" onclick="doLogin()">Anmelden</button>
    <div class="l-err" id="l-err">❌ Benutzername oder Passwort falsch</div>
    <div style="text-align:center;margin-top:20px">
      <button onclick="showScreen('home-screen')" style="background:none;border:none;color:rgba(255,255,255,.45);font-size:15px;cursor:pointer;font-family:'Nunito',sans-serif">← Zurück</button>
    </div>
  </div>
</div>

<!-- ═══════ ADMIN SCREEN ═══════ -->
<div id="admin-screen" class="screen">
  <div class="a-hdr">
    <div class="a-logo">⚙️</div>
    <div><div class="a-ttl">Admin-Bereich</div><div class="a-sub">Susi Companion V4</div></div>
    <button class="a-back" onclick="showScreen('home-screen')">← App</button>
  </div>
  <div class="a-tabs">
    <button class="a-tab active" onclick="switchTab('tp-users')">👥 Nutzer</button>
    <button class="a-tab" onclick="switchTab('tp-modules')">🧩 Module</button>
    <button class="a-tab" onclick="switchTab('tp-termine')">📅 Termine</button>
    <button class="a-tab" onclick="switchTab('tp-avatar')">💬 Avatar</button>
    <button class="a-tab" onclick="switchTab('tp-news')">📰 Inhalte</button>
    <button class="a-tab" onclick="switchTab('tp-system')">🔒 System</button>
  </div>
  <div class="a-body">

    <div class="tpane active" id="tp-users">
      <div class="a-sec">
        <div class="a-sec-ttl">👥 Alle Nutzer</div>
        <div id="admin-user-list"></div>
        <button class="a-btn" onclick="addNewUser()" style="margin-top:8px">+ Neuen Nutzer anlegen</button>
      </div>
      <div class="a-sec" id="user-edit-sec" style="display:none">
        <div class="a-sec-ttl">✏️ Nutzer bearbeiten</div>
        <div class="a-lbl">Vorname</div><input class="a-in" id="ue-name" placeholder="z.B. Hildegard" oninput="saveUser()"/>
        <div class="a-lbl">Standort / Stadt</div><input class="a-in" id="ue-loc" placeholder="z.B. Wien" oninput="saveUser()"/>
        <div class="a-lbl">WhatsApp-Nummer</div><input class="a-in" id="ue-wa" placeholder="+43 664 ..." oninput="saveUser()"/>
        <div class="a-lbl">Notfallkontakt 1</div>
        <div class="a-row"><input class="a-in" id="ue-ec1n" placeholder="z.B. Tochter Maria" oninput="saveUser()"/><input class="a-in" id="ue-ec1p" placeholder="+43 ..." oninput="saveUser()" style="max-width:140px"/></div>
        <div class="a-lbl">Notfallkontakt 2</div>
        <div class="a-row"><input class="a-in" id="ue-ec2n" placeholder="z.B. Sohn Klaus" oninput="saveUser()"/><input class="a-in" id="ue-ec2p" placeholder="+43 ..." oninput="saveUser()" style="max-width:140px"/></div>
        <button class="a-btn danger" onclick="deleteUser()">🗑 Nutzer löschen</button>
      </div>
    </div>


    <!-- MODULE TAB -->
    <div class="tpane" id="tp-modules">
      <div class="a-sec">
        <div class="a-sec-ttl">🔲 Buttons ein-/ausblenden</div>
        <div style="font-size:14px;color:rgba(255,255,255,.55);margin-bottom:18px;font-weight:600;line-height:1.6">
          Alle 6 Buttons bleiben im Grid. Ausgeblendete Buttons werden ausgegraut und gesperrt.<br>
          <span style="color:rgba(255,255,255,.35)">Termine und Notfall können nicht deaktiviert werden.</span>
        </div>
        <div id="module-toggle-list"></div>
      </div>
      <div class="a-sec">
        <div class="a-sec-ttl">⚙️ Zusatz-Features</div>
        <div style="font-size:14px;color:rgba(255,255,255,.55);margin-bottom:18px;font-weight:600;line-height:1.6">
          Diese Features sind optional und können pro Installation aktiviert werden.
        </div>

        <!-- Feature 1: Arzt-Zugang -->
        <div style="display:flex;align-items:flex-start;gap:14px;background:rgba(43,159,216,.12);border:1px solid rgba(43,159,216,.3);border-radius:14px;padding:16px 18px;margin-bottom:12px;">
          <div style="font-size:28px;margin-top:2px">👨‍⚕️</div>
          <div style="flex:1">
            <div style="font-size:17px;font-weight:900">Arzt-Zugang (Option 1)</div>
            <div style="font-size:13px;color:rgba(255,255,255,.5);font-weight:600;margin-top:3px">Arzt oder Sprechstundenhilfe kann per PIN Medikamente und Termine per Sprache eingeben – ohne Admin-Zugang.</div>
          </div>
          <label style="position:relative;display:inline-block;width:52px;height:28px;flex-shrink:0;margin-top:2px">
            <input type="checkbox" id="feat-doctor" onchange="toggleFeature('doctor')" style="opacity:0;width:0;height:0;position:absolute"/>
            <span id="feat-track-doctor" style="position:absolute;inset:0;border-radius:14px;cursor:pointer;transition:.3s;background:rgba(255,255,255,.2)">
              <span id="feat-knob-doctor" style="position:absolute;height:20px;width:20px;left:4px;bottom:4px;background:white;border-radius:50%;transition:.3s;display:block"></span>
            </span>
          </label>
        </div>

        <!-- Feature 2: GPS & lokale Nachrichten -->
        <div style="display:flex;align-items:flex-start;gap:14px;background:rgba(37,194,96,.1);border:1px solid rgba(37,194,96,.3);border-radius:14px;padding:16px 18px;margin-bottom:12px;">
          <div style="font-size:28px;margin-top:2px">📍</div>
          <div style="flex:1">
            <div style="font-size:17px;font-weight:900">GPS & lokale Nachrichten (Option 2)</div>
            <div style="font-size:13px;color:rgba(255,255,255,.5);font-weight:600;margin-top:3px">GPS-Button oben sichtbar, Nachrichten und Wetter beziehen sich auf den Standort des Nutzers.</div>
          </div>
          <label style="position:relative;display:inline-block;width:52px;height:28px;flex-shrink:0;margin-top:2px">
