// ═══════════════ CLOCK ═══════════════
function updateClock(){
  const n=new Date(), h=String(n.getHours()).padStart(2,'0'), m=String(n.getMinutes()).padStart(2,'0');
  document.getElementById('clock').textContent=h+':'+m;
  const days=['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
  const months=['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
  document.getElementById('datepill').textContent=days[n.getDay()]+', '+n.getDate()+'. '+months[n.getMonth()];
}
updateClock(); setInterval(updateClock,15000);

// ═══════════════ SPEECH ═══════════════
const synth = ('speechSynthesis' in window) ? window.speechSynthesis : null;
let mouthT=null;
function susiSay(text,cb){
  if(!text) return;
  setBubble(text);
  if(!synth){ if(cb) cb(); return; }
  synth.cancel(); startMouth(); document.getElementById('sdw').classList.add('on');
  const u=new SpeechSynthesisUtterance(text); u.lang='de-DE'; u.rate=0.93; u.pitch=1.12; u.volume=1;
  const vv=synth.getVoices(); const v=vv.find(v=>v.lang==='de-DE'&&/anna|female|frau/i.test(v.name))||vv.find(v=>v.lang==='de-DE')||vv.find(v=>v.lang.startsWith('de'));
  if(v)u.voice=v;
  u.onend=()=>{ stopMouth(); document.getElementById('sdw').classList.remove('on'); if(cb)cb(); };
  synth.speak(u);
}
function setBubble(t){ const td=document.getElementById('tdots'); if(td)td.classList.remove('on'); const b=document.getElementById('bubble-text'); if(b){b.style.display='block';b.textContent=t;} }
function startMouth(){
  clearInterval(mouthT); let o=false;
  mouthT=setInterval(()=>{ o=!o;
    const ms=document.getElementById('m-smile'),mo=document.getElementById('m-open'),mt=document.getElementById('m-teeth'),ml=document.getElementById('m-lower');
    if(!ms)return;
    if(o){ ms.setAttribute('d','M68 94 Q80 102 92 94'); mo.setAttribute('opacity','0.9'); mt.setAttribute('opacity','0.9'); mo.setAttribute('rx',String(6+Math.random()*4)); mo.setAttribute('ry',String(3+Math.random()*4)); ml.setAttribute('opacity','0'); }
    else{ ms.setAttribute('d','M68 99 Q80 108 92 99'); mo.setAttribute('opacity','0'); mt.setAttribute('opacity','0'); ml.setAttribute('opacity','0.5'); }
  }, 180+Math.random()*80);
}
function stopMouth(){ clearInterval(mouthT); const ms=document.getElementById('m-smile'); if(!ms)return; ms.setAttribute('d','M68 99 Q80 108 92 99'); document.getElementById('m-open').setAttribute('opacity','0'); document.getElementById('m-teeth').setAttribute('opacity','0'); document.getElementById('m-lower').setAttribute('opacity','0.5'); }
if(synth && 'onvoiceschanged' in synth){ synth.onvoiceschanged=()=>{}; }

// ═══════════════ OVERLAYS ═══════════════
function openOv(id){ document.getElementById(id).classList.add('on'); document.body.style.overflow='hidden'; }
function closeOv(id){ document.getElementById(id).classList.remove('on'); document.body.style.overflow=''; }
