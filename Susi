async function parseSpokenTermin(spoken){
  const vstatus=document.getElementById('voice-status');
  const key=D.apiKey||'';
  let termin=null;

  if(key){
    try{
      const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01'},body:JSON.stringify({
        model:'claude-sonnet-4-20250514',max_tokens:200,
        system:'Du extrahierst aus einem gesprochenen Satz einen Termin oder eine Medikamentenerinnerung. Antworte NUR als JSON ohne Markdown in diesem Format: {"time":"HH:MM","emoji":"emoji","text":"Kurztext","sub":"Details oder leer","repeat":"täglich/wöchentlich/einmalig"}. Verwende passende Emojis: 💊 für Medikamente, 🏥 für Arzttermine, 🩺 für Untersuchungen.',
        messages:[{role:'user',content:'Analysiere diesen Satz: "'+spoken+'"'}]
      })});
      const data=await res.json(); const txt=data.content?.[0]?.text||'';
      termin=JSON.parse(txt.replace(/```json?|```/g,'').trim());
    }catch(e){}
  }

  if(!termin){ termin=parseTerminFallback(spoken); }
  if(!termin){ vstatus.textContent='❌ Konnte keinen Termin erkennen. Bitte manuell eingeben.'; setTimeout(()=>vstatus.classList.remove('on'),4000); return; }

  parsedTermin=termin;
  vstatus.classList.remove('on');
  const prev=document.getElementById('parsed-preview'); prev.classList.add('on');
  document.getElementById('pp-content').innerHTML=`
    <div class="pp-item">${termin.emoji||'📌'} ${termin.text}</div>
    <div class="pp-sub">🕐 ${termin.time||'?'}${termin.sub?' · '+termin.sub:''}</div>
    ${termin.repeat&&termin.repeat!=='einmalig'?`<div class="pp-sub">🔄 ${termin.repeat}</div>`:''}
  `;
}

function parseTerminFallback(spoken){
  const s=spoken.toLowerCase();
  const timeMatch=s.match(/(\d{1,2})(?::(\d{2}))?\s*uhr/);
  let time='08:00';
  if(timeMatch){ const h=String(timeMatch[1]).padStart(2,'0'); const m=String(timeMatch[2]||'0').padStart(2,'0'); time=h+':'+m; }
  let emoji='📌',text=spoken,sub='',repeat='einmalig';
  if(/tablette|pille|medikament|aspirin|ibuprofen|blutdruck|herz|vitamin/i.test(s)){emoji='💊';text='Medikament einnehmen';sub=spoken;repeat=/täglich|jeden tag|morgens|abends/i.test(s)?'täglich':'einmalig';}
  else if(/arzt|doktor|kontrolle|untersuchung|praxis|klinik|krankenhaus/i.test(s)){emoji='🏥';text='Arzttermin';sub=spoken;}
  else if(/frühstück/i.test(s)){emoji='🍳';text='Frühstück';}
  else if(/mittag/i.test(s)){emoji='🍽️';text='Mittagessen';}
  return {time,emoji,text,sub,repeat};
}

