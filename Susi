// ═══════════════ GPS ═══════════════
function toggleGPS(){
  if(D.gpsEnabled){ D.gpsEnabled=false; D.gpsLat=null; D.gpsLon=null; D.gpsCity=''; save(); updateGPSUI(); return; }
  if(!navigator.geolocation){ alert('GPS ist in diesem Browser nicht verfügbar.'); return; }
  document.getElementById('gps-pill').textContent='📍 Suche...';
  navigator.geolocation.getCurrentPosition(pos=>{
    D.gpsLat=pos.coords.latitude; D.gpsLon=pos.coords.longitude; D.gpsEnabled=true;
    // Reverse geocode with nominatim (free, no key needed)
    fetch(`https://nominatim.openstreetmap.org/reverse?lat=${D.gpsLat}&lon=${D.gpsLon}&format=json`)
      .then(r=>r.json()).then(data=>{
        D.gpsCity = data.address?.city || data.address?.town || data.address?.village || data.address?.county || '';
        save(); updateGPSUI();
        susiSay('GPS aktiviert! Ich sehe, du bist in ' + (D.gpsCity||'deiner Stadt') + '. Ich zeige dir jetzt lokale Nachrichten und das Wetter für deinen Standort!');
      }).catch(()=>{ save(); updateGPSUI(); });
  }, ()=>{ alert('GPS-Zugriff wurde verweigert. Bitte in den Browser-Einstellungen erlauben.'); document.getElementById('gps-pill').textContent='📍 GPS'; });
}

function updateGPSUI(){
  const pill=document.getElementById('gps-pill');
  if(D.gpsEnabled){ pill.textContent='📍 '+(D.gpsCity||'GPS ✓'); pill.classList.add('on'); document.getElementById('news-sub-label').textContent=D.gpsCity?'Lokal: '+D.gpsCity:'Lokal & Welt'; }
  else{ pill.textContent='📍 GPS'; pill.classList.remove('on'); document.getElementById('news-sub-label').textContent='Lokal & Welt'; }
}

// ═══════════════ WETTER ═══════════════
const weatherIcons={Clear:'☀️',Clouds:'⛅',Rain:'🌧️',Drizzle:'🌦️',Thunderstorm:'⛈️',Snow:'❄️',Mist:'🌫️',Fog:'🌫️',Haze:'🌫️'};
const weatherTips={Clear:'Herrliches Wetter – ein Spaziergang wäre schön!',Clouds:'Leicht bewölkt – gute Bedingungen für draußen.',Rain:'Regenwetter – bitte Regenschirm mitnehmen!',Snow:'Schnee – bitte warm anziehen und vorsichtig gehen!',Thunderstorm:'Gewitter – besser drinnen bleiben!',default:'Denk an eine Jacke, wenn es kühler wird.'};

async function loadWeather(){
  const owmKey=D.owmKey||'';
  if(!owmKey){ loadWeatherFallback(); return; }
  if(!D.gpsEnabled||!D.gpsLat){ loadWeatherByCity(owmKey); return; }
  try{
    const r=await fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${D.gpsLat}&lon=${D.gpsLon}&appid=${owmKey}&units=metric&lang=de`);
    const data=await r.json(); applyWeather(data);
  }catch(e){ loadWeatherFallback(); }
}

async function loadWeatherByCity(key){
  const city=D.gpsCity||(activeUser()?.location||'Wien');
  try{
    const r=await fetch(`https://api.openweathermap.org/data/2.5/weather?q=${encodeURIComponent(city)}&appid=${key}&units=metric&lang=de`);
    const data=await r.json(); applyWeather(data);
  }catch(e){ loadWeatherFallback(); }
}

function applyWeather(data){
  const main=data.weather?.[0]?.main||'Clear';
  const desc=data.weather?.[0]?.description||'Schönes Wetter';
  const temp=Math.round(data.main?.temp||18);
  const hum=data.main?.humidity||60;
  const wind=Math.round((data.wind?.speed||5)*3.6);
  const pop=Math.round((data.pop||0.2)*100);
  const city=data.name||D.gpsCity||'Deinen Ort';
  document.getElementById('wt-ico').textContent=weatherIcons[main]||'🌤️';
  document.getElementById('wt-temp').textContent=temp+'°';
  document.getElementById('wt-desc').textContent=desc.charAt(0).toUpperCase()+desc.slice(1);
  document.getElementById('wt-loc').textContent='📍 '+city;
  document.getElementById('wt-hum').textContent=hum+'%';
  document.getElementById('wt-wind').textContent=wind+' km/h';
  document.getElementById('wt-rain').textContent=pop+'%';
  document.getElementById('wt-tip').textContent='🌡️ '+(weatherTips[main]||weatherTips.default);
  susiSay(`Das Wetter in ${city}: ${temp} Grad, ${desc}. ${weatherTips[main]||weatherTips.default}`);
}

function loadWeatherFallback(){
  const city=D.gpsCity||(activeUser()?.location||'deiner Stadt');
  document.getElementById('wt-ico').textContent='⛅';
  document.getElementById('wt-temp').textContent='18°';
  document.getElementById('wt-desc').textContent='Teilweise bewölkt';
  document.getElementById('wt-loc').textContent='📍 '+(D.gpsEnabled?city:'Standort nicht aktiv');
  document.getElementById('wt-hum').textContent='65%';
  document.getElementById('wt-wind').textContent='12 km/h';
  document.getElementById('wt-rain').textContent='20%';
  document.getElementById('wt-tip').textContent=D.owmKey?'⚠️ Wetterdaten konnten nicht geladen werden.':'💡 Tipp: OpenWeatherMap API-Key im Admin eintragen für echte Wetterdaten!';
  susiSay('Das Wetter in '+city+': Etwa 18 Grad, teilweise bewölkt. Denk an eine Jacke!');
}

// ═══════════════ NACHRICHTEN ═══════════════
async function loadNews(){
  const body=document.getElementById('mb-news');
  const city=D.gpsCity||(activeUser()?.location||'');
  // RSS via allorigins proxy (kostenlos, kein Key)
  let items=[];

  // Custom news first
  if(D.customNews?.length){
    items.push(...D.customNews.map(n=>({cat:'📋 Eigene Nachricht',ttl:n.title,sum:n.text,time:'Aktuell',url:null})));
  }

  // Try RSS feed (ORF/regional)
  const feeds=[];
  if(D.gpsEnabled && city){
    feeds.push(`https://www.google.com/alerts/feeds/03805780930063854688/6025282048494565745`); // placeholder
  }
  // Standard Austrian/German feeds via rss2json
  const rssFeeds=[
    {url:'https://rss.orf.at/news.xml',cat:'📺 ORF Nachrichten'},
    {url:'https://www.derstandard.at/rss',cat:'📰 Der Standard'},
  ];
  // We'll use allorigins.win to bypass CORS
  let loaded=false;
  for(const feed of rssFeeds){
    try{
      const proxy=`https://api.allorigins.win/get?url=${encodeURIComponent(feed.url)}`;
      const r=await fetch(proxy,{signal:AbortSignal.timeout(4000)});
      if(!r.ok) continue;
      const data=await r.json();
      const parser=new DOMParser();
      const xml=parser.parseFromString(data.contents,'text/xml');
      const entries=xml.querySelectorAll('item');
      entries.forEach((it,i)=>{
        if(i>=3)return;
        const ttl=it.querySelector('title')?.textContent||'';
        const sum=it.querySelector('description')?.textContent?.replace(/<[^>]*>/g,'').substring(0,120)||'';
        const link=it.querySelector('link')?.textContent||null;
        const pub=it.querySelector('pubDate')?.textContent||'';
        const d=pub?new Date(pub):new Date();
        const timeStr=d.toLocaleDateString('de-AT',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
        items.push({cat:feed.cat,ttl,sum,time:timeStr,url:link});
      });
      loaded=true; break;
    }catch(e){}
  }

  if(!loaded){
    items.push(
      {cat:'🌍 International',ttl:'Nachrichten werden geladen',sum:'Bitte GPS aktivieren und Internetverbindung prüfen.',time:'Jetzt',url:null},
      {cat:'💡 Tipp',ttl:'GPS aktivieren für lokale Nachrichten',sum:'Drücke auf das GPS-Symbol oben rechts, um lokale Nachrichten zu erhalten.',time:'',url:null},
    );
  }

  // Prepend local GPS context
  if(D.gpsEnabled && city){
    items.unshift({cat:'📍 Lokal: '+city,ttl:'Standort erkannt: '+city,sum:'Lokale Nachrichten und Wetter für deinen Bereich sind aktiviert.',time:'Jetzt',url:null});
  }

  body.innerHTML=items.map(n=>`
    <div class="news-item">
      <div class="news-cat">${n.cat}</div>
      <div class="news-ttl">${n.ttl}</div>
      <div class="news-sum">${n.sum}</div>
      ${n.time?`<div class="news-time">🕐 ${n.time}</div>`:''}
      ${n.url?`<div class="news-src" onclick="window.open('${n.url}','_blank')">→ Ganzen Artikel lesen</div>`:''}
    </div>`).join('');
  document.getElementById('badge-n').textContent=items.length;
}

