function renderWA(){
  const u=activeUser(); const num=u?.whatsapp||'';
  const groups=[
    {emoji:'👨‍👩‍👧‍👦',bg:'#e8f5e9',name:'Familie',prev:'Mama, kommst du Sonntag?',time:'09:12',count:3},
    {emoji:'👭',bg:'#e3f2fd',name:'Freundinnen-Runde',prev:'Wir treffen uns um 15 Uhr 🌸',time:'Gestern',count:2},
  ];
  document.getElementById('mb-wa').innerHTML=groups.map(g=>`
    <div class="wa-grp" onclick="openWA('${num}')">
      <div class="wa-ava" style="background:${g.bg}">${g.emoji}</div>
      <div style="flex:1"><div class="wa-name">${g.name}</div><div class="wa-prev">${g.prev}</div><div class="wa-time">${g.time}</div></div>
